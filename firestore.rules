rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated and belongs to org
    function isOrgMember(orgId) {
      return request.auth != null &&
        request.auth.token.orgId == orgId;
    }

    function isAdmin(orgId) {
      return isOrgMember(orgId) &&
        request.auth.token.role in ['admin', 'manager'];
    }

    function isTechnician(orgId) {
      return isOrgMember(orgId) &&
        request.auth.token.role == 'technician';
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if request.auth != null;
      allow update: if isAdmin(orgId);
    }

    // Users
    match /users/{userId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if request.auth != null;
      allow update: if request.auth.uid == userId || isAdmin(resource.data.orgId);
    }

    // Assets
    match /assets/{assetId} {
      // Public: can read limited fields (name, category, location, status, photoUrl, qrCodeUrl)
      allow read: if true;
      allow create: if isAdmin(resource.data.orgId);
      allow update: if isAdmin(resource.data.orgId);
      allow delete: if isAdmin(resource.data.orgId);
    }

    // Issues
    match /issues/{issueId} {
      // Public can create issues (report)
      allow create: if true;
      // Org members can read their org's issues
      allow read: if isOrgMember(resource.data.orgId);
      // Admin/manager can update any issue in their org
      allow update: if isAdmin(resource.data.orgId)
        // Technician can update issues assigned to them
        || (isTechnician(resource.data.orgId) && resource.data.assignedTo == request.auth.uid);
    }

    // Service History
    match /serviceHistory/{logId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if isOrgMember(resource.data.orgId);
    }
  }
}

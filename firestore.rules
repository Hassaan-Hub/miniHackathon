rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Simple auth check
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user profile exists in Firestore
    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Get user data — only safe to call AFTER hasUserDoc() check
    function userOrgId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Composite checks
    function isOrgMember(orgId) {
      return hasUserDoc() && userOrgId() == orgId;
    }

    function isAdmin(orgId) {
      return isOrgMember(orgId) && userRole() in ['admin', 'manager'];
    }

    function isTechnician(orgId) {
      return isOrgMember(orgId) && userRole() == 'technician';
    }

    // ---- Collections ----

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isSignedIn();
      allow update: if isAdmin(orgId);
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId
        || (hasUserDoc() && userOrgId() == resource.data.orgId);
      allow create: if isSignedIn();
      allow update: if request.auth.uid == userId
        || (hasUserDoc() && userRole() in ['admin', 'manager']);
    }

    match /assets/{assetId} {
      allow read: if true;
      allow create: if hasUserDoc() && userRole() in ['admin', 'manager'];
      allow update: if hasUserDoc() && userRole() in ['admin', 'manager'];
      allow delete: if hasUserDoc() && userRole() in ['admin', 'manager'];
    }

    match /issues/{issueId} {
      allow create: if true;
      allow read: if isOrgMember(resource.data.orgId);
      allow update: if isAdmin(resource.data.orgId)
        || (isTechnician(resource.data.orgId) && resource.data.assignedTo == request.auth.uid);
    }

    match /serviceHistory/{logId} {
      allow read: if isOrgMember(resource.data.orgId);
      allow create: if hasUserDoc();
    }
  }
}
